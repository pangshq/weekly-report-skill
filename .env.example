# 邮件服务器配置（QQ邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
# 587 端口这里必须为 false
secure=false
# 强制使用 TLS 加密
requireTLS=true
SMTP_USER=your-qq@qq.com
SMTP_PASS=your-auth-code

# 收件人（固定）
RECIPIENT=recipient@example.com

# 是否为金融行业从业者（true/false）
# 金融行业从业者周末不上班，A股不开市，直接跳过发送
FINANCE_INDUSTRY=false

# 员工姓名（用于周报标题和署名）
EMPLOYEE_NAME=周小报